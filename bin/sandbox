#!/usr/bin/env bash
# sandbox <name> [name2...] [flags]
# Session entry point: shell, agent CLI, or command. Auto-tmux for multiple containers.
#
# Examples:
#   sandbox proj-alpha                        # shell into one
#   sandbox proj-alpha proj-beta              # tmux with shells
#   sandbox proj-alpha --agent codex          # run codex
#   sandbox proj-alpha --agent claude         # run claude
#   sandbox proj-alpha proj-beta --agent codex  # tmux with codex
#   sandbox proj-alpha --cmd "git status"     # run command
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

print_help() {
  cat <<'EOF'
Purpose:
  Open a shell, run an agent CLI, or execute a command inside one or more
  running sandboxes. Multiple sandboxes open in a tmux session automatically.

Usage:
  sandbox <name> [name2 ...] [--agent <name>] [--cmd "<command>"] [--claude]

Flags:
  --agent <name>   Run the selected agent CLI instead of an interactive shell.
  --cmd "<cmd>"    Run the command inside each target container.
  --claude         Backward-compatible alias for --agent claude.
  -h, --help       Show this help text.

Defaults:
  With no mode flag, sandbox opens an interactive shell.

Examples:
  sandbox proj-alpha
  sandbox proj-alpha --agent codex
  sandbox proj-alpha proj-beta --agent codex
  sandbox proj-alpha --cmd "git status"
EOF
}

# ── Parse args ──────────────────────────────────────────────────────
NAMES=()
MODE="shell"   # shell | agent | cmd
CMD=""
REQUESTED_AGENT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_help; exit 0 ;;
    --claude) MODE="agent"; REQUESTED_AGENT="claude"; shift ;;
    --agent)  [[ -n "${2:-}" ]] || die "--agent requires a value"; MODE="agent"; REQUESTED_AGENT="$2"; shift 2 ;;
    --cmd)    [[ -n "${2:-}" ]] || die "--cmd requires a value"; MODE="cmd"; CMD="$2"; shift 2 ;;
    --*)      die "Unknown flag: $1
Try 'sandbox --help' for usage." ;;
    *)        NAMES+=("$1"); shift ;;
  esac
done

[[ ${#NAMES[@]} -gt 0 ]] || die "Container name required.
Try 'sandbox --help' for usage."

require_sandbox

# ── Build the command to run in each container ──────────────────────
SESSION_CMD_ARGS=()

shell_quote_args() {
  local quoted=()
  local arg
  for arg in "$@"; do
    quoted+=("$(printf '%q' "$arg")")
  done

  local IFS=' '
  echo "${quoted[*]}"
}

build_session_args() {
  local name="$1"
  local container
  container=$(container_name "$name")

  SESSION_CMD_ARGS=()
  if [[ "$SANDBOX_PLATFORM" == "macos" ]]; then
    SESSION_CMD_ARGS+=(orb run -m "${SANDBOX_MACHINE}" sudo)
  fi

  SESSION_CMD_ARGS+=(
    incus exec "${container}"
    --user "${SANDBOX_UID}"
    --group "${SANDBOX_GID}"
    --cwd "${WORKSPACE_DIR}"
    --env "HOME=${SANDBOX_USER_HOME}"
    --
  )

  case "$MODE" in
    shell)
      SESSION_CMD_ARGS+=(bash --login)
      ;;
    agent)
      local resolved_agent launch_command
      resolved_agent=$(resolve_container_agent_id "$container" "$REQUESTED_AGENT")
      launch_command=$(agent_launch_command "$resolved_agent")
      SESSION_CMD_ARGS+=(bash --login -c "$launch_command")
      ;;
    cmd)
      SESSION_CMD_ARGS+=(bash --login -c "$CMD")
      ;;
  esac
}

# ── Validate all containers exist and are running ───────────────────
for name in "${NAMES[@]}"; do
  container=$(container_name "$name")
  require_container "$container"
  state=$(vm_exec "incus info ${container} 2>/dev/null | grep 'Status:' | awk '{print \$2}'" || true)
  if [[ "$state" != "RUNNING" ]]; then
    die "Container '${container}' is ${state}, not running. Run 'sandbox-start ${name}' to restart it."
  fi
done

# ── Single container: direct session ────────────────────────────────
if [[ ${#NAMES[@]} -eq 1 ]]; then
  build_session_args "${NAMES[0]}"
  exec "${SESSION_CMD_ARGS[@]}"
fi

# ── Multiple containers: tmux ───────────────────────────────────────
require_command tmux

SESSION="sandbox-agents"
tmux kill-session -t "$SESSION" 2>/dev/null || true

# First pane
build_session_args "${NAMES[0]}"
FIRST_CMD=$(shell_quote_args "${SESSION_CMD_ARGS[@]}")
tmux new-session -d -s "$SESSION" -n "agents" "$FIRST_CMD"

# Remaining panes
for ((i=1; i<${#NAMES[@]}; i++)); do
  build_session_args "${NAMES[$i]}"
  PANE_CMD=$(shell_quote_args "${SESSION_CMD_ARGS[@]}")
  tmux split-window -t "$SESSION" "$PANE_CMD"
  tmux select-layout -t "$SESSION" tiled
done

tmux attach-session -t "$SESSION"
