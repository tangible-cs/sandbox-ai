#!/usr/bin/env bash
# sandbox-start <name> [repo-url] [flags]
# Create a new agent container from a golden image, or restart a stopped one
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

print_help() {
  cat <<'EOF'
Purpose:
  Create a new sandbox from a golden image or restart an existing stopped one.

Usage:
  sandbox-start <name> [repo-url] [flags]

Flags:
  --stack <name>          Golden image stack to use. Default: base.
  --branch <name>         Branch to check out after cloning the repo.
  --from <name>           Inherit repo and selected settings from another sandbox.
  --ssh-key <path>        Use an existing private key instead of generating one.
  --slot <N>              Reserve a specific slot instead of auto-assigning one.
  --cpu <N>               Apply an Incus CPU limit.
  --memory <value>        Apply an Incus memory limit, for example 8GiB.
  --env KEY=VALUE         Inject an environment variable. Repeatable.
  --agent <name>          Install an agent CLI in the sandbox. Repeatable.
  --default-agent <name>  Set the default agent CLI for sandbox <name>.
  --restrict-domains      Restrict HTTPS egress to the merged allowlist.
  --domains-file <path>   Add domains from a custom allowlist file.
  -h, --help              Show this help text.

Defaults:
  The default stack is base.
  If no --agent flags are given, sandbox-start installs Codex and sets it as
  the default agent.

Examples:
  sandbox-start proj-alpha git@github.com:me/repo.git
  sandbox-start proj-alpha git@github.com:me/repo.git --stack rust --agent codex
  sandbox-start proj-multi git@github.com:me/repo.git --agent claude --agent codex --default-agent codex
  sandbox-start proj-safe --restrict-domains --domains-file ./domains.txt
EOF
}

# ── Parse args ──────────────────────────────────────────────────────
NAME=""
REPO=""
STACK="base"
BRANCH=""
FROM=""
SSH_KEY=""
SLOT=""
CPU=""
MEMORY=""
EXTRA_ENVS=()
RESTRICT_DOMAINS=""
DOMAINS_FILE=""
AGENT_IDS=()
DEFAULT_AGENT=""

# ── Helpers ──────────────────────────────────────────────────────
apply_domain_filtering() {
  local container="$1" domains_file="$2"
  shift 2
  local selected_agents=("$@")
  local resolved_file resolved_name container_ip

  resolved_file=$(write_merged_agent_allowlist_file "$domains_file" "${selected_agents[@]}")
  resolved_name=$(basename "$resolved_file")

  container_ip=$(get_container_ip "$container")
  [[ -n "$container_ip" ]] || die "Could not determine container IP for domain filtering"

  setup_container_domain_filter "$container" "$resolved_file" "$container_ip"
  redirect_container_to_squid "$container_ip"
  vm_run iptables -I FORWARD -s "${container_ip}" -o "${OUTBOUND_IFACE}" -p udp --dport 443 -j DROP

  ok "Domain filtering active (${resolved_name})"
}

print_connection_summary() {
  local container="$1" name="$2" status_word="$3"
  local slot stack_name ssh_p app_p alt_p

  slot=$(get_metadata "$container" "slot")
  stack_name=$(get_metadata "$container" "stack")
  ssh_p=$(ssh_port "$slot")
  app_p=$(app_port "$slot")
  alt_p=$(alt_port "$slot")

  echo ""
  ok "=== '${container}' ${status_word} ==="
  echo ""
  echo "  Slot:      ${slot}"
  echo "  Stack:     ${stack_name:-unknown}"
  if [[ "$(get_metadata "$container" "restrict-domains")" == "yes" ]]; then
    echo "  Domains:   RESTRICTED"
  else
    echo "  Domains:   open (all HTTPS allowed)"
  fi
  echo "  SSH:       ssh -o StrictHostKeyChecking=no -p ${ssh_p} ubuntu@localhost"
  echo "  VS Code:   code --remote ssh-remote+ubuntu@localhost:${ssh_p} ${WORKSPACE_DIR}"
  echo "  App:       http://localhost:${app_p}"
  echo "  Alt:       http://localhost:${alt_p}"
  local installed_agents default_agent
  installed_agents=$(get_installed_agents_metadata "$container")
  default_agent=$(get_default_agent_metadata "$container")
  [[ -n "$installed_agents" ]] && echo "  Agents:    ${installed_agents}"
  [[ -n "$default_agent" ]] && echo "  Default:   ${default_agent}"
  echo ""
  echo "  Shell:     sandbox ${name}"
  [[ -n "$default_agent" ]] && echo "  Agent:     sandbox ${name} --agent ${default_agent}"
  echo "  Codex:     sandbox ${name} --agent codex"
  echo "  Claude:    sandbox ${name} --agent claude"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)           print_help; exit 0 ;;
    --stack)            [[ -n "${2:-}" ]] || die "--stack requires a value"; STACK="$2"; shift 2 ;;
    --branch)           [[ -n "${2:-}" ]] || die "--branch requires a value"; BRANCH="$2"; shift 2 ;;
    --from)             [[ -n "${2:-}" ]] || die "--from requires a value"; FROM="$2"; shift 2 ;;
    --ssh-key)          [[ -n "${2:-}" ]] || die "--ssh-key requires a value"; SSH_KEY="$2"; shift 2 ;;
    --slot)             [[ -n "${2:-}" ]] || die "--slot requires a value"; SLOT="$2"; shift 2 ;;
    --cpu)              [[ -n "${2:-}" ]] || die "--cpu requires a value"; CPU="$2"; shift 2 ;;
    --memory)           [[ -n "${2:-}" ]] || die "--memory requires a value"; MEMORY="$2"; shift 2 ;;
    --env)              [[ -n "${2:-}" ]] || die "--env requires a value"; EXTRA_ENVS+=("$2"); shift 2 ;;
    --agent)            [[ -n "${2:-}" ]] || die "--agent requires a value"; AGENT_IDS+=("$2"); shift 2 ;;
    --default-agent)    [[ -n "${2:-}" ]] || die "--default-agent requires a value"; DEFAULT_AGENT="$2"; shift 2 ;;
    --restrict-domains) RESTRICT_DOMAINS="yes"; shift ;;
    --domains-file)     [[ -n "${2:-}" ]] || die "--domains-file requires a value"; RESTRICT_DOMAINS="yes"; DOMAINS_FILE="$2"; shift 2 ;;
    --*)                die "Unknown flag: $1
Try 'sandbox-start --help' for usage." ;;
    *)
      if [[ -z "$NAME" ]]; then
        NAME="$1"
      elif [[ -z "$REPO" ]]; then
        REPO="$1"
      else
        die "Unexpected argument: $1"
      fi
      shift
      ;;
  esac
done

[[ -n "$NAME" ]] || die "Sandbox name required.
Try 'sandbox-start --help' for usage."

validate_stack "$STACK"
[[ -n "$CPU" ]] && validate_cpu "$CPU"
[[ -n "$MEMORY" ]] && validate_memory "$MEMORY"

if [[ ${#AGENT_IDS[@]} -gt 0 ]]; then
  SELECTED_AGENTS_CSV=$(resolve_selected_agents "${AGENT_IDS[@]}")
else
  SELECTED_AGENTS_CSV=$(resolve_selected_agents)
fi
SELECTED_AGENT_IDS=()
while IFS= read -r agent_id; do
  [[ -n "$agent_id" ]] || continue
  SELECTED_AGENT_IDS+=("$agent_id")
done < <(parse_agent_ids "$SELECTED_AGENTS_CSV")
DEFAULT_AGENT=$(select_default_agent "$DEFAULT_AGENT" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"})

# ── Check for existing container (restart-or-create) ──────────────
require_sandbox
CONTAINER=$(container_name "$NAME")

CONTAINER_STATE=""
if vm_run incus info "${CONTAINER}" >/dev/null 2>&1; then
  CONTAINER_STATE=$(container_status "$CONTAINER" || true)
fi

if [[ "$CONTAINER_STATE" == "RUNNING" ]]; then
  die "Container '${CONTAINER}' is already running. Use 'sandbox ${NAME}' to connect."
fi

if [[ "$CONTAINER_STATE" == "STOPPED" ]]; then
  # ── Restart path: reconfigure in-place ────────────────────────────
  info "Restarting stopped container '${CONTAINER}'..."

  # Error on flags that can't be changed in-place
  IMMUTABLE_ERROR=""
  [[ "$STACK" != "base" ]] && IMMUTABLE_ERROR+="  --stack (cannot change stack on restart)\n"
  [[ -n "$FROM" ]]         && IMMUTABLE_ERROR+="  --from (cannot change source on restart)\n"
  [[ -n "$REPO" ]]         && IMMUTABLE_ERROR+="  --repo (cannot change repo on restart)\n"
  [[ -n "$BRANCH" ]]       && IMMUTABLE_ERROR+="  --branch (cannot change branch on restart)\n"
  [[ -n "$SLOT" ]]         && IMMUTABLE_ERROR+="  --slot (cannot change slot on restart)\n"
  [[ ${#AGENT_IDS[@]} -gt 0 ]] && IMMUTABLE_ERROR+="  --agent (cannot change selected agents on restart)\n"
  [[ -n "$DEFAULT_AGENT" && "$DEFAULT_AGENT" != "$(get_default_agent_metadata "$CONTAINER")" ]] && IMMUTABLE_ERROR+="  --default-agent (cannot change default agent on restart)\n"
  if [[ -n "$IMMUTABLE_ERROR" ]]; then
    die "Cannot change these flags on restart (destroy and recreate instead):\n${IMMUTABLE_ERROR}Use 'sandbox-stop ${NAME} --rm' first, then 'sandbox-start ${NAME} ...' to recreate."
  fi

  # Start the container
  vm_run incus start "${CONTAINER}"

  # Wait for networking
  wait_for_container_networking "$CONTAINER"

  # Ensure workspace directory exists (may be missing in containers from old golden images)
  vm_run incus exec "${CONTAINER}" -- install -d -o "${SANDBOX_UID}" -g "${SANDBOX_GID}" "${WORKSPACE_DIR}"

  # Apply reconfigurable flags if provided
  if [[ -n "$CPU" ]]; then
    info "Updating CPU limit to ${CPU}..."
    vm_run incus config set "${CONTAINER}" "limits.cpu=${CPU}"
  fi
  if [[ -n "$MEMORY" ]]; then
    info "Updating memory limit to ${MEMORY}..."
    vm_run incus config set "${CONTAINER}" "limits.memory=${MEMORY}"
  fi

  # Inject extra env vars (appends new ones to bashrc)
  if [[ ${#EXTRA_ENVS[@]} -gt 0 ]]; then
    info "Injecting environment variables..."
    inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}
  fi

  # Handle --ssh-key: replace deploy key in container and update SSH config
  if [[ -n "$SSH_KEY" ]]; then
    [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
    info "Replacing SSH key..."
    ssh_agent_cleanup "$CONTAINER"
    ssh_agent_setup "$CONTAINER" "$SSH_KEY"
  else
    # Restart SSH agent using existing key on disk
    info "Restarting SSH agent..."
    ssh_agent_restart "$CONTAINER"
  fi

  # Handle domain filtering updates
  if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
    info "Applying domain-based egress filtering..."
    apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"}
    set_metadata "$CONTAINER" "restrict-domains" "yes"
    [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
  else
    EXISTING_RESTRICT=$(get_metadata "$CONTAINER" "restrict-domains")
    if [[ "$EXISTING_RESTRICT" == "yes" ]]; then
      info "Re-applying domain filtering from saved configuration..."
      EXISTING_DOMAINS_FILE=$(get_metadata "$CONTAINER" "domains-file")
      EXISTING_AGENT_IDS=()
      while IFS= read -r agent_id; do
        [[ -n "$agent_id" ]] || continue
        EXISTING_AGENT_IDS+=("$agent_id")
      done < <(effective_container_agent_ids "$CONTAINER")
      apply_domain_filtering "$CONTAINER" "$EXISTING_DOMAINS_FILE" ${EXISTING_AGENT_IDS[@]+"${EXISTING_AGENT_IDS[@]}"}
    fi
  fi

  print_connection_summary "$CONTAINER" "$NAME" "restarted"
  exit 0
fi

# ── Container doesn't exist: create from scratch ──────────────────

# ── Resolve --from ──────────────────────────────────────────────────
if [[ -n "$FROM" ]]; then
  FROM_CONTAINER=$(container_name "$FROM")

  if [[ -z "$REPO" ]]; then
    REPO=$(vm_run incus exec "${FROM_CONTAINER}" -- \
      git -c "safe.directory=${WORKSPACE_DIR}" -C "${WORKSPACE_DIR}" remote get-url origin 2>/dev/null || true)
    [[ -n "$REPO" ]] || die "Could not determine repo URL from container '${FROM_CONTAINER}'"
    info "Inherited repo: ${REPO}"
  fi

  if [[ "$STACK" == "base" ]]; then
    FROM_STACK=$(get_metadata "$FROM_CONTAINER" "stack")
    if [[ -n "$FROM_STACK" ]]; then
      STACK="$FROM_STACK"
      info "Inherited stack: ${STACK}"
    fi
  fi

  if [[ -z "$SSH_KEY" ]]; then
    FROM_KEY="${SANDBOX_KEY_DIR}/deploy_${FROM}"
    if [[ -f "$FROM_KEY" ]]; then
      # Don't reuse the key — generate a new one for this container
      info "Will generate new deploy key (not reusing from '${FROM}')"
    fi
  fi

  # Inherit domain restriction if not explicitly set
  if [[ -z "$RESTRICT_DOMAINS" ]]; then
    FROM_RESTRICT=$(get_metadata "$FROM_CONTAINER" "restrict-domains")
    if [[ "$FROM_RESTRICT" == "yes" ]]; then
      RESTRICT_DOMAINS="yes"
      info "Inherited domain restriction from '${FROM}'"
      if [[ -z "$DOMAINS_FILE" ]]; then
        FROM_DOMAINS_FILE=$(get_metadata "$FROM_CONTAINER" "domains-file")
        if [[ -n "$FROM_DOMAINS_FILE" ]]; then
          DOMAINS_FILE="$FROM_DOMAINS_FILE"
          info "Inherited domains file: ${DOMAINS_FILE}"
        fi
      fi
    fi
  fi
fi

# ── Validate ────────────────────────────────────────────────────────
require_golden "$STACK"

# ── Auto-assign or validate slot ────────────────────────────────────
if [[ -z "$SLOT" ]]; then
  SLOT=$(next_free_slot)
  info "Auto-assigned slot: ${SLOT}"
else
  validate_slot "$SLOT"
fi

SSH_P=$(ssh_port "$SLOT")
APP_P=$(app_port "$SLOT")
ALT_P=$(alt_port "$SLOT")

# ── Deploy key (auto-generate if repo provided and no --ssh-key) ───
KEY_PATH=""
if [[ -n "$REPO" && -z "$SSH_KEY" ]]; then
  require_gh
  deploy_key_create "$NAME" "$REPO"
  KEY_PATH="${SANDBOX_KEY_DIR}/deploy_${NAME}"
elif [[ -n "$SSH_KEY" ]]; then
  [[ -f "$SSH_KEY" ]] || die "SSH key not found: ${SSH_KEY}"
  KEY_PATH="$SSH_KEY"
fi

# ── Create container ────────────────────────────────────────────────
info "Creating '${CONTAINER}' from golden-${STACK}/ready (slot ${SLOT})..."

vm_run incus copy "golden-${STACK}/ready" "${CONTAINER}"

# Resource limits (only if explicitly set)
if [[ -n "$CPU" ]]; then
  vm_run incus config set "${CONTAINER}" "limits.cpu=${CPU}"
fi
if [[ -n "$MEMORY" ]]; then
  vm_run incus config set "${CONTAINER}" "limits.memory=${MEMORY}"
fi

# Proxy devices for port forwarding
vm_run incus config device add "${CONTAINER}" ssh-proxy proxy \
  "listen=tcp:127.0.0.1:${SSH_P}" "connect=tcp:127.0.0.1:22"
vm_run incus config device add "${CONTAINER}" app-proxy proxy \
  "listen=tcp:127.0.0.1:${APP_P}" "connect=tcp:127.0.0.1:8080"
vm_run incus config device add "${CONTAINER}" alt-proxy proxy \
  "listen=tcp:127.0.0.1:${ALT_P}" "connect=tcp:127.0.0.1:9090"

# Start
vm_run incus start "${CONTAINER}"
sleep 3

# ── Host SSH key (for user SSH access) ────────────────────────────
HOST_PUBKEY=""
for keyfile in ~/.ssh/id_ed25519.pub ~/.ssh/id_rsa.pub ~/.ssh/id_ecdsa.pub; do
  if [[ -f "$keyfile" ]]; then
    HOST_PUBKEY=$(cat "$keyfile")
    break
  fi
done
if [[ -n "$HOST_PUBKEY" ]]; then
  # Inject for ubuntu user (primary SSH access)
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c "cat >> ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chmod 600 ${SANDBOX_USER_HOME}/.ssh/authorized_keys && chown ${SANDBOX_UID}:${SANDBOX_GID} ${SANDBOX_USER_HOME}/.ssh/authorized_keys"
  # Keep root too for emergency access
  echo "$HOST_PUBKEY" | vm_run incus exec "${CONTAINER}" -- \
    bash -c 'cat >> /root/.ssh/authorized_keys && chmod 600 /root/.ssh/authorized_keys'
  ok "Host SSH key injected"
else
  warn "No SSH public key found (~/.ssh/id_*.pub) — SSH access requires manual key setup"
fi

# ── SSH agent ───────────────────────────────────────────────────────
if [[ -n "$KEY_PATH" ]]; then
  info "Setting up SSH agent..."
  ssh_agent_setup "$CONTAINER" "$KEY_PATH"
fi

# ── Env vars ────────────────────────────────────────────────────────
inject_env "$CONTAINER" ${EXTRA_ENVS[@]+"${EXTRA_ENVS[@]}"}

# ── Selected agent CLIs ─────────────────────────────────────────────
ensure_container_agent_runtime_prereqs "$CONTAINER" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"}
install_selected_agent_clis "$CONTAINER" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"}

# ── Domain filtering ───────────────────────────────────────────────
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  info "Applying domain-based egress filtering..."
  apply_domain_filtering "$CONTAINER" "$DOMAINS_FILE" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"}
fi

# ── Store metadata ──────────────────────────────────────────────────
set_metadata "$CONTAINER" "slot" "$SLOT"
set_metadata "$CONTAINER" "stack" "$STACK"
set_installed_agents_metadata "$CONTAINER" ${SELECTED_AGENT_IDS[@]+"${SELECTED_AGENT_IDS[@]}"}
set_default_agent_metadata "$CONTAINER" "$DEFAULT_AGENT"
[[ -n "$REPO" ]] && set_metadata "$CONTAINER" "repo" "$REPO"
if [[ "$RESTRICT_DOMAINS" == "yes" ]]; then
  set_metadata "$CONTAINER" "restrict-domains" "yes"
  [[ -n "$DOMAINS_FILE" ]] && set_metadata "$CONTAINER" "domains-file" "$DOMAINS_FILE"
fi

# ── Clone repo ──────────────────────────────────────────────────────
if [[ -n "$REPO" ]]; then
  info "Cloning repository..."

  # Configure safe.directory for ubuntu user and clone as ubuntu
  vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" --env "HOME=${SANDBOX_USER_HOME}" -- \
    git config --global safe.directory '*' \
    || die "Failed to configure git safe.directory in ${CONTAINER}"
  vm_run incus exec "${CONTAINER}" \
    --user "${SANDBOX_UID}" \
    --group "${SANDBOX_GID}" \
    --env "HOME=${SANDBOX_USER_HOME}" \
    --env "SSH_AUTH_SOCK=/run/ssh-agent.sock" \
    -- \
    git clone "${REPO}" "${WORKSPACE_DIR}" \
    || die "Git clone failed. Check SSH key and repo access."

  # Switch to requested branch (checkout if it exists remotely, create if it doesn't)
  if [[ -n "$BRANCH" ]]; then
    vm_run incus exec "${CONTAINER}" \
      --user "${SANDBOX_UID}" \
      --group "${SANDBOX_GID}" \
      --env "HOME=${SANDBOX_USER_HOME}" \
      -- \
      bash -s -- "${WORKSPACE_DIR}" "${BRANCH}" <<'EOF' || die "Failed to switch to branch '${BRANCH}'"
workspace_dir="$1"
branch_name="$2"
cd "$workspace_dir"
git checkout "$branch_name" 2>/dev/null || git checkout -b "$branch_name"
EOF
    ok "Repository cloned (branch: ${BRANCH})"
  else
    ok "Repository cloned"
  fi
fi

# Ensure workspace directory exists for scratch containers (no repo)
if [[ -z "$REPO" ]]; then
  vm_run incus exec "${CONTAINER}" --user "${SANDBOX_UID}" --group "${SANDBOX_GID}" -- \
    mkdir -p "${WORKSPACE_DIR}"
fi

# ── Done ────────────────────────────────────────────────────────────
print_connection_summary "$CONTAINER" "$NAME" "ready"
