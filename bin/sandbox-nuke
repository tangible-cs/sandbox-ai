#!/usr/bin/env bash
# sandbox-nuke
# Destroy ALL agent containers, golden images, and optionally the OrbStack VM.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

print_help() {
  cat <<'EOF'
Purpose:
  Destroy every sandbox container, every golden image, and local deploy-key
  material. On macOS it also deletes the OrbStack sandbox VM.

Usage:
  sandbox-nuke

Flags:
  -h, --help   Show this help text.

Defaults:
  The command is destructive and always prompts for confirmation.

Examples:
  sandbox-nuke
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_help; exit 0 ;;
    *) die "Unknown flag: $1
Try 'sandbox-nuke --help' for usage." ;;
  esac
done

require_sandbox

echo "This will destroy ALL agent containers, golden images, and deploy keys."
read -p "Are you sure? (yes/no): " CONFIRM
[[ "$CONFIRM" == "yes" ]] || { echo "Aborted"; exit 0; }

# Ensure the OrbStack VM and local keys are always cleaned up, even if
# container/golden-image cleanup fails midway (set -e from sandbox-common.sh
# would otherwise abort the script before reaching the final teardown).
nuke_cleanup() {
  if [[ -d "${SANDBOX_KEY_DIR}" ]]; then
    rm -rf "${SANDBOX_KEY_DIR}"
    info "Cleaned up local deploy keys"
  fi
  if [[ "$SANDBOX_PLATFORM" == "macos" ]]; then
    info "Destroying OrbStack machine '${SANDBOX_MACHINE}'..."
    orb delete -f "${SANDBOX_MACHINE}" 2>/dev/null || true
    ok "OrbStack machine destroyed"
  fi
}
trap nuke_cleanup EXIT

# Get list of containers before destroying them
CONTAINERS=$(vm_exec "incus list -f csv -c n 2>/dev/null | grep '^agent-'" || true)

for container in $CONTAINERS; do
  name="${container#agent-}"

  # Clean up SSH agent
  ssh_agent_cleanup "$container"

  # Clean up domain filtering (Squid ACL)
  cleanup_container_domain_filter "$container"

  # Clean up deploy key
  repo=$(get_metadata "$container" "repo")
  if [[ -n "$repo" ]]; then
    deploy_key_cleanup "$name" "$repo"
  fi

  # Clean up egress rules (FORWARD + NAT)
  container_ip=$(get_container_ip "$container")
  if [[ -n "$container_ip" ]]; then
    remove_container_squid_redirect "$container_ip"
    cleanup_container_forward_rules "$container_ip"
  fi

  info "Destroying ${container}..."
  vm_exec "incus delete '${container}' --force"
done

info "Destroying golden images..."
vm_exec "
  for g in \$(incus list -f csv -c n 2>/dev/null | grep '^golden-'); do
    echo \"Destroying \$g...\"
    incus delete \"\$g\" --force
  done
"
ok "Containers and golden images destroyed."
ok "Everything destroyed. Run 'sandbox-setup' to rebuild."
