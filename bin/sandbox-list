#!/usr/bin/env bash
# sandbox-list — List all agent containers with health status
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/sandbox-common.sh"

require_sandbox

CONTAINERS=$(vm_exec "incus list -f csv -c n 2>/dev/null | grep '^agent-' || true")

if [[ -z "$CONTAINERS" ]]; then
  echo "No agent containers found"
  exit 0
fi

printf "\n%-25s %-9s %-5s %-6s %-6s %-6s %-20s %-10s %-8s %-8s %-14s %-24s %s\n" \
  "CONTAINER" "STATE" "SLOT" "SSH" "APP" "ALT" "EXTRA" "EGRESS" "DOCKER" "SSHAGENT" "DEFAULT" "AUTH" "REPO"
printf "%-25s %-9s %-5s %-6s %-6s %-6s %-20s %-10s %-8s %-8s %-14s %-24s %s\n" \
  "─────────" "─────" "────" "───" "───" "───" "─────" "──────" "──────" "────────" "───────" "────" "────"

for c in $CONTAINERS; do
  state=$(vm_exec "incus info ${c} 2>/dev/null | grep 'Status:' | awk '{print \$2}'" || true)

  ssh_p=$(vm_exec "incus config device get ${c} ssh-proxy listen 2>/dev/null | grep -o '[0-9]*$' || echo '-'" || true)
  app_p=$(vm_exec "incus config device get ${c} app-proxy listen 2>/dev/null | grep -o '[0-9]*$' || echo '-'" || true)
  alt_p=$(vm_exec "incus config device get ${c} alt-proxy listen 2>/dev/null | grep -o '[0-9]*$' || echo '-'" || true)

  if [[ "$ssh_p" != "-" ]]; then
    slot=$(( ssh_p - 2200 ))
  else
    slot="-"
  fi

  extras=""
  while IFS= read -r dev; do
    [[ -n "$dev" ]] || continue
    listen_port=$(vm_exec "incus config device get ${c} ${dev} listen 2>/dev/null | grep -o '[0-9]*$' || true" || true)
    connect_port=$(vm_exec "incus config device get ${c} ${dev} connect 2>/dev/null | grep -o '[0-9]*$' || true" || true)
    if [[ -n "$listen_port" ]]; then
      [[ -n "$extras" ]] && extras="${extras},"
      if [[ -n "$connect_port" && "$listen_port" != "$connect_port" ]]; then
        extras="${extras}${listen_port}→${connect_port}"
      else
        extras="${extras}${listen_port}"
      fi
    fi
  done < <(vm_exec "incus config device list ${c} 2>/dev/null | grep '^port-' || true")
  [[ -n "$extras" ]] || extras="-"

  egress_status="open"
  if [[ "$(get_metadata "$c" "restrict-domains")" == "yes" ]]; then
    egress_status="filtered"
  fi

  docker_status="-"
  ssh_agent_status="-"
  repo_info="-"
  default_agent=$(resolve_container_agent_id "$c" "")
  installed_agents=()
  while IFS= read -r agent_id; do
    [[ -n "$agent_id" ]] || continue
    installed_agents+=("$agent_id")
  done < <(effective_container_agent_ids "$c")
  auth_status="-"

  if [[ "$state" == "RUNNING" ]]; then
    if vm_exec "incus exec ${c} -- docker info &>/dev/null"; then
      docker_status="ok"
    else
      docker_status="err"
    fi

    agent_out=$(vm_exec "incus exec ${c} -- bash -c 'SSH_AUTH_SOCK=/run/ssh-agent.sock ssh-add -l 2>&1' || true" || true)
    if echo "$agent_out" | grep -q "no identities"; then
      ssh_agent_status="no-key"
    elif echo "$agent_out" | grep -q "Could not open\|Error\|refused"; then
      ssh_agent_status="none"
    elif echo "$agent_out" | grep -qE "^[0-9]"; then
      ssh_agent_status="ok"
    else
      ssh_agent_status="none"
    fi

    auth_status=$(format_agent_auth_statuses "$c" "${installed_agents[@]}")

    if vm_exec "incus exec ${c} -- test -d ${WORKSPACE_DIR}/.git 2>/dev/null"; then
      remote=$(vm_exec "incus exec ${c} -- git -c safe.directory=${WORKSPACE_DIR} -C ${WORKSPACE_DIR} remote get-url origin 2>/dev/null | sed -E 's#.*github\\.com[:/]##; s#\\.git\$##' || echo '?'" || true)
      branch=$(vm_exec "incus exec ${c} -- git -c safe.directory=${WORKSPACE_DIR} -C ${WORKSPACE_DIR} branch --show-current 2>/dev/null || echo '?'" || true)
      repo_info="${remote} (${branch})"
    fi
  fi

  printf "%-25s %-9s %-5s %-6s %-6s %-6s %-20s %-10s %-8s %-8s %-14s %-24s %s\n" \
    "$c" "$state" "$slot" "$ssh_p" "$app_p" "$alt_p" "$extras" \
    "$egress_status" "$docker_status" "$ssh_agent_status" "$default_agent" "$auth_status" "$repo_info"
done

echo ""
