#!/usr/bin/env bash
# sandbox-setup — One-time setup: creates OrbStack machine, installs Incus, builds golden image
set -euo pipefail

MACHINE="sandbox"

echo "=== Step 1: Creating OrbStack machine '${MACHINE}' ==="
if orb list 2>/dev/null | grep -q "${MACHINE}"; then
  echo "Machine '${MACHINE}' already exists, skipping creation"
else
  orb create ubuntu:noble "${MACHINE}"
  echo "Machine created"
fi

echo ""
echo "=== Step 2: Installing Incus ==="
orb run -m "${MACHINE}" bash << 'SETUP'
set -e

if command -v incus &>/dev/null; then
  echo "Incus already installed: $(incus version)"
else
  curl -fsSL https://pkgs.zabbly.com/key.asc | gpg --dearmor -o /etc/apt/keyrings/zabbly.gpg
  cat > /etc/apt/sources.list.d/zabbly-incus.list << EOF
deb [signed-by=/etc/apt/keyrings/zabbly.gpg] https://pkgs.zabbly.com/incus/stable $(. /etc/os-release && echo $VERSION_CODENAME) main
EOF
  apt-get update
  apt-get install -y incus btrfs-progs

  cat << INIT | incus admin init --preseed
config: {}
networks:
  - config:
      ipv4.address: 10.100.0.1/24
      ipv4.nat: "true"
      ipv6.address: none
    description: ""
    name: incusbr0
    type: bridge
storage_pools:
  - config: {}
    description: ""
    name: default
    driver: btrfs
profiles:
  - config: {}
    description: ""
    devices:
      eth0:
        name: eth0
        network: incusbr0
        type: nic
      root:
        path: /
        pool: default
        type: disk
    name: default
INIT

  echo "Incus initialized: $(incus version)"
fi
SETUP

echo ""
echo "=== Step 3: Building golden image ==="
orb run -m "${MACHINE}" bash << 'GOLDEN'
set -e

if incus info golden &>/dev/null; then
  echo "Golden container already exists"
  if incus snapshot list golden -f csv 2>/dev/null | grep -q "ready"; then
    echo "Golden snapshot 'ready' exists — setup complete"
    exit 0
  fi
  echo "Golden exists but no 'ready' snapshot, rebuilding..."
  incus delete golden --force 2>/dev/null || true
fi

echo "Launching base container..."
incus launch images:ubuntu/24.04 golden \
  -c security.nesting=true \
  -c security.syscalls.intercept.mknod=true \
  -c security.syscalls.intercept.setxattr=true

sleep 5
incus exec golden -- cloud-init status --wait 2>/dev/null || true

echo "Installing dev tools (this takes a few minutes)..."
incus exec golden -- bash << 'INNER'
set -e
export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y \
  curl git tmux openssh-server ripgrep jq htop wget unzip \
  build-essential ca-certificates gnupg lsb-release \
  python3 python3-pip python3-venv

# Docker
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
  https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
  > /etc/apt/sources.list.d/docker.list
apt-get update
apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin

# Node.js LTS
curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
apt-get install -y nodejs

# Claude Code
npm install -g @anthropic-ai/claude-code

# SSH config
mkdir -p /run/sshd
sed -i 's/#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sed -i 's/#PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
echo "root:sandbox" | chpasswd

systemctl enable docker
systemctl enable ssh

mkdir -p /workspace

apt-get clean
rm -rf /var/lib/apt/lists/*
echo "Golden image tools installed"
INNER

incus stop golden
incus snapshot create golden ready
echo "Golden snapshot 'ready' created"
GOLDEN

echo ""
echo "=== Setup complete ==="
echo ""
echo "Next steps:"
echo "  1. Add scripts to your PATH: export PATH=\"\$PATH:$(cd "$(dirname "$0")" && pwd)\""
echo "  2. Export your API key: export ANTHROPIC_API_KEY=sk-ant-..."
echo "  3. Create your first sandbox: sandbox-create my-project 1 git@github.com:you/repo.git"
