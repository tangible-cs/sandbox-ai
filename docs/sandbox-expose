#!/usr/bin/env bash
# sandbox-expose <n> <host-port> <container-port> [protocol]
set -euo pipefail

NAME="${1:?Usage: sandbox-expose <n> <host-port> <container-port> [protocol]}"
HOST_PORT="${2:?Host port required}"
CONTAINER_PORT="${3:?Container port required}"
PROTO="${4:-tcp}"
CONTAINER="agent-${NAME}"

orb run -m sandbox incus config device add "${CONTAINER}" "port-${HOST_PORT}" proxy \
  "listen=${PROTO}:0.0.0.0:${HOST_PORT}" \
  "connect=${PROTO}:127.0.0.1:${CONTAINER_PORT}"

echo "Exposed ${CONTAINER}:${CONTAINER_PORT} → localhost:${HOST_PORT} (${PROTO})"
