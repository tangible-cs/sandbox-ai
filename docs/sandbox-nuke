#!/usr/bin/env bash
# sandbox-nuke — Remove ALL agent containers. Pass --all to also remove golden image.
set -euo pipefail
FLAG="${1:-}"

echo "This will destroy ALL agent containers."
read -p "Are you sure? (yes/no): " CONFIRM
[ "$CONFIRM" = "yes" ] || { echo "Aborted"; exit 0; }

orb run -m sandbox bash << EOF
for c in \$(incus list -f csv -c n 2>/dev/null | grep "^agent-"); do
  echo "Destroying \$c..."
  incus delete "\$c" --force
done

if [ "${FLAG}" = "--all" ]; then
  echo "Destroying golden image..."
  incus delete golden --force 2>/dev/null || true
  echo "Everything destroyed. Run sandbox-setup to rebuild."
else
  echo "All agent containers destroyed. Golden image preserved."
fi
EOF
