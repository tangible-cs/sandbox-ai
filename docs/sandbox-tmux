#!/usr/bin/env bash
# sandbox-tmux [name1] [name2] ... — Open tmux with one pane per agent
# If no names given, opens panes for ALL running agent containers.

SESSION="agents"
tmux kill-session -t "$SESSION" 2>/dev/null || true

if [ $# -gt 0 ]; then
  CONTAINERS=("$@")
else
  mapfile -t CONTAINERS < <(orb run -m sandbox incus list -f csv -c n status=running 2>/dev/null | grep "^agent-" | sed 's/^agent-//')
fi

if [ ${#CONTAINERS[@]} -eq 0 ]; then
  echo "No agent containers found"
  exit 1
fi

echo "Opening tmux with ${#CONTAINERS[@]} panes:"
for c in "${CONTAINERS[@]}"; do echo "  - agent-${c}"; done

# First pane
FIRST="${CONTAINERS[0]}"
SSH_PORT=$(orb run -m sandbox incus config device get "agent-${FIRST}" ssh-proxy listen 2>/dev/null | grep -oP ':\K\d+$')
tmux new-session -d -s "$SESSION" -n "agents" \
  "ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p ${SSH_PORT} root@localhost"

# Remaining panes
for ((i=1; i<${#CONTAINERS[@]}; i++)); do
  NAME="${CONTAINERS[$i]}"
  SSH_PORT=$(orb run -m sandbox incus config device get "agent-${NAME}" ssh-proxy listen 2>/dev/null | grep -oP ':\K\d+$')
  tmux split-window -t "$SESSION" \
    "ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p ${SSH_PORT} root@localhost"
  tmux select-layout -t "$SESSION" tiled
done

tmux attach-session -t "$SESSION"
